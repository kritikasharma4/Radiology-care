# Copy this to .env and fill in real values

# Server
API_HOST=0.0.0.0
API_PORT=8000

# CORS — comma-separated list of allowed frontend origins
# On Render: set this to your Vercel app URL, e.g. https://radiology-care.vercel.app
ALLOWED_ORIGINS=https://your-app.vercel.app

# Demo authentication — change these before any client demo
DEMO_USERNAME=radiologist
DEMO_PASSWORD=radcare2024
API_SECRET_KEY=change-this-to-a-random-secret

# AI provider: openai | claude | mock
AI_PROVIDER=openai
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the local ETL import source directory
# ETL_SOURCE_DIR=C:\path\to\patient\images
